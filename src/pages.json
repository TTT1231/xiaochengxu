{
   "easycom": {
      "autoscan": true,
      "custom": {
         "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
         "^(?!z-paging-refresh|(?!utf-16-slice-string).*-item|(?!utf-16-slice-string).*-wrapper|(?!utf-16-slice-string).*-demo|(?!utf-16-slice-string).*-mixin).*": "@/components/$1.vue"
      }
   },
   "pages": [
      {
         "path": "pages/index/index",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "点单"
         }
      },
      {
         "path": "pages/order/index",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "订单"
         }
      },
      {
         "path": "pages/profile/index",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "我的"
         }
      },
      {
         "path": "pages/profile/edit",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "个人资料"
         }
      },
      {
         "path": "pages/wallet/index",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "我的余额"
         }
      },
      {
         "path": "pages/vip-redeem/index",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "会员卡兑换"
         }
      },
      {
         "path": "pages/profile/privacy",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "隐私政策"
         }
      },
      {
         "path": "pages/profile/agreement",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "用户协议"
         }
      },
      {
         "path": "pages/profile/business",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "经营公示"
         }
      },
      {
         "path": "pages/cart/index",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "购物车"
         }
      },
      {
         "path": "pages/order/detail",
         "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "订单详情"
         }
      },
      {
         "path": "pages/show-product-details/show-product-details",
         "style": {
            "navigationBarTitleText": ""
         }
      }
   ],
   "globalStyle": {
      "navigationBarTextStyle": "black",
      "navigationBarTitleText": "甜品屋",
      "navigationBarBackgroundColor": "#ffffff",
      "backgroundColor": "#fbf6ef"
   },
   "tabBar": {
      "custom": true,
      "color": "#aa9688",
      "selectedColor": "#a54f1b",
      "backgroundColor": "#ffffff",
      "borderStyle": "white",
      "list": [
         {
            "pagePath": "pages/index/index",
            "text": "首页",
            "iconPath": "static/icons/tabbar/tab-home.png",
            "selectedIconPath": "static/icons/tabbar/tab-home-active.png"
         },
         {
            "pagePath": "pages/order/index",
            "text": "订单",
            "iconPath": "static/icons/tabbar/tab-order.png",
            "selectedIconPath": "static/icons/tabbar/tab-order-active.png"
         },
         {
            "pagePath": "pages/profile/index",
            "text": "我的",
            "iconPath": "static/icons/tabbar/tab-profile.png",
            "selectedIconPath": "static/icons/tabbar/tab-profile-active.png"
         }
      ]
   }
}

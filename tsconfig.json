{
   "extends": "@vue/tsconfig/tsconfig.json",
   "compilerOptions": {
      "sourceMap": true,
      "paths": {
         "@/*": ["./src/*"]
      },
      "lib": ["esnext", "dom"],
      "types": ["@dcloudio/types"],
      "verbatimModuleSyntax": true
   },
   "include": [
      "src/**/*.ts",
      "src/**/*.d.ts",
      "src/**/*.tsx",
      "src/**/*.vue",
      "weixin-cloud/**/*.ts",
      "weixin-cloud/**/*.d.ts"
   ]
}

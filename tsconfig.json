{
   "extends": "@vue/tsconfig/tsconfig.json",
   "compilerOptions": {
      "sourceMap": true,
      "paths": {
         "@/*": ["./src/*"]
      },
      "lib": ["esnext", "dom"],
      "types": ["@dcloudio/types"],
      "ignoreDeprecations": "6.0",
      "importsNotUsedAsValues": "remove",
      "preserveValueImports": false
   },
   "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"]
}

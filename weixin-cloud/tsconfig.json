{
   "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "moduleResolution": "bundler"
   },
   "include": ["utils/**/*.ts", "**/*.test.ts"],
   "exclude": ["node_modules"]
}
